<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for Night mode. -->
    <style name="Theme.UASPBO" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Menghilangkan ActionBar secara paksa -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Primary brand color. -->
        <item name="colorPrimary">#0A2A66</item>
        <item name="colorPrimaryVariant">#05183D</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">#0A2A66</item>
    </style>
</resources>